{
  "csv_path": "data/ag/v4.csv",
  "target_col": "wheat_weekly_rv",
  "target_horizons": [1, 4, 8, 12, 16],
  "use_cache": true,
  "cache_dir": ".cache/benchmark",
  "cache_overwrite": false,
  "target_mode": "point",
  "core_columns": [
    "wheat_weekly_rv",
    "wheat_monthly_rv",
    "wheat_seasonal_rv"
  ],
  "run_configs": {
    "xgb_expanding": {
      "walk_forward": {
        "window_type": "expanding",
        "initial_train_size": 260,
        "test_size": 4,
        "step": 4
      },
      "model": {
        "n_estimators": 400,
        "max_depth": 6,
        "learning_rate": 0.05,
        "subsample": 0.8,
        "colsample_bytree": 0.8,
        "min_child_weight": 1.0,
        "reg_alpha": 0.0,
        "reg_lambda": 1.0,
        "objective": "reg:squarederror",
        "random_state": 42,
        "n_jobs": -1,
        "target_transform": "log",
        "log_transform_rv_features": true
      }
    },
    "xgb_rolling": {
      "walk_forward": {
        "window_type": "rolling",
        "initial_train_size": 260,
        "test_size": 4,
        "step": 4,
        "rolling_window_size": 260
      },
      "model": {
        "n_estimators": 400,
        "max_depth": 6,
        "learning_rate": 0.05,
        "subsample": 0.8,
        "colsample_bytree": 0.8,
        "min_child_weight": 1.0,
        "reg_alpha": 0.0,
        "reg_lambda": 1.0,
        "objective": "reg:squarederror",
        "random_state": 42,
        "n_jobs": -1,
        "target_transform": "log",
        "log_transform_rv_features": true
      }
    }
  },
  "grid_search": {
    "enabled": true,
    "metric": "test_r2",
    "maximize_metric": true,
    "initial_train_sizes": [208, 260, 312],
    "test_sizes": [2, 4, 8],
    "steps": [2, 4, 8],
    "n_estimators": [200, 400, 600],
    "max_depths": [4, 6, 8],
    "learning_rates": [0.03, 0.05, 0.1],
    "min_child_weights": [1.0, 3.0, 5.0],
    "max_candidates": 60
  }
}
